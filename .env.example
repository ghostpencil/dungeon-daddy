# Copy this file to .env and fill in your actual keys.
# .env is gitignored — never commit real credentials.

# Required — drives the dungeon wizard and DM (GPT-4o)
OPENAI_API_KEY=sk-your-key-here

# Optional — override the OpenAI model (default: gpt-4o)
DUNGEON_DADDY_MODEL=gpt-4o

# Required for smoke tests only (Strategy B vision classifier)
ANTHROPIC_API_KEY=sk-ant-your-key-here
